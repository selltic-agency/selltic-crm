# ── Supabase (Project Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...          # publiczny, OK w przeglądarce
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...             # SEKRET — tylko serwer, nigdy w kliencie

# ── Powiadomienia mailowe (opcjonalne, https://resend.com) ──
RESEND_API_KEY=re_xxxxx
RESEND_FROM=Selltic <leady@twoja-domena.pl>

# ── Cron (przypomnienia o zadaniach) ──
# Sekret chroniący /api/cron/reminders. Ustaw w Vercel → Settings → Environment
# Variables; Vercel Cron automatycznie dołącza nagłówek Authorization: Bearer <CRON_SECRET>.
# W produkcji bez tej zmiennej endpoint zwraca 503 (celowo zablokowany).
CRON_SECRET=wygeneruj-dlugi-losowy-ciag

# ── Prospecting (import leadów z zewnętrznego scrapera Google Maps) ──
# Sekret chroniący /api/prospecting/import i /api/prospecting/existing-ids.
# Scraper wysyła go w nagłówku X-API-Key. Wygeneruj długi losowy ciąg, np.:
#   openssl rand -hex 32
# Ustaw w Vercel → Settings → Environment Variables. Bez tej zmiennej
# endpointy zwracają 503 (celowo zablokowane).
SCRAPER_IMPORT_KEY=wygeneruj-dlugi-losowy-ciag

# ── Scraper headless (zakładka "Scraper" — architektura bez Streamlit UI) ──
# Adres nowej usługi Cloud Run (webhook_server.py, FastAPI) w repo
# selltic-scraper. BEZ ukośnika na końcu.
SCRAPER_WEBHOOK_URL=https://selltic-scraper-webhook-xxxxx.a.run.app
# Sekret chroniący POST {SCRAPER_WEBHOOK_URL}/webhook/scrape.
# CRM wysyła go w nagłówku Authorization: Bearer <SCRAPER_WEBHOOK_SECRET>.
# MUSI być identyczny jak SCRAPER_WEBHOOK_SECRET ustawiony na Cloud Run
# (usługa selltic-scraper-webhook). Wygeneruj długi losowy ciąg, np.:
#   openssl rand -hex 32
SCRAPER_WEBHOOK_SECRET=wygeneruj-dlugi-losowy-ciag
